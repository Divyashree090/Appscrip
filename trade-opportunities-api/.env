# ─────────────────────────────────────────────
# Trade Opportunities API - Environment Config
# ─────────────────────────────────────────────

# REQUIRED: Get your free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# REQUIRED: Change this to a random secret string for production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Optional: Application settings
APP_ENV=development
LOG_LEVEL=INFO

# Optional: Rate limiting (defaults shown)
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW=3600

# Optional: Cache TTL in seconds (default: 1800 = 30 min)
# CACHE_TTL=1800
